{
	"name": "sveltalot",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"engines": {
		"npm": "please use pnpm",
		"yarn": "please use pnpm",
		"node": "22"
	},
	"scripts": {
		"postinstall": "node ./scripts/scrapeDato/index.mjs",
		"dev": "vite dev",
		"prebuild": "node ./scripts/scrapeDato/index.mjs",
		"build": "vite build",
		"prepare": "lefthook install",
		"postbuild": "node ./scripts/postbuild/index.js",
		"preview": "vite preview",
		"start": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "eslint --fix .",
		"generate-graphql": "graphql-codegen --config codegen.ts",
		"watch-graphql": "graphql-codegen --watch --config codegen.ts",
		"component": "node ./scripts/component/index.js",
		"state": "node ./scripts/state/index.js",
		"favicons": "node ./scripts/favicon/index.js",
		"icons": "node ./scripts/icon/index.js"
	},
	"lint-staged": {
		"**/*.(js|ts|svelte|svelte.ts|svelte.js)": [
			"eslint --fix"
		],
		"**/*.(js|json|ts|svelte|svelte.ts|svelte.js)": [
			"prettier --write"
		]
	},
	"devDependencies": {
		"@csstools/postcss-global-data": "^3.0.0",
		"@eslint/compat": "^1.2.3",
		"@graphql-codegen/cli": "5.0.3",
		"@graphql-codegen/client-preset": "4.5.1",
		"@graphql-codegen/introspection": "4.0.3",
		"@graphql-codegen/typescript-graphql-request": "^6.2.0",
		"@graphql-codegen/typescript-operations": "^4.4.0",
		"@parcel/watcher": "^2.5.0",
		"@sveltejs/adapter-vercel": "^5.5.0",
		"@sveltejs/enhanced-img": "^0.4.4",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"autoprefixer": "^10.4.20",
		"dotenv": "^16.4.7",
		"eslint": "^9.7.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.36.0",
		"favicons": "^7.2.0",
		"generate-robotstxt": "^8.0.3",
		"globals": "^15.0.0",
		"graphql-tag": "^2.12.6",
		"postcss-preset-env": "^10.1.3",
		"prettier": "^3.3.2",
		"prettier-plugin-svelte": "^3.2.6",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"svelte-sitemap": "^2.7.0",
		"svgo": "^3.3.2",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.0.0",
		"vite": "^5.4.11"
	},
	"dependencies": {
		"@types/node": "^22.13.4",
		"embla-carousel": "^8.5.2",
		"graphql": "^16.10.0",
		"graphql-request": "^7.1.2",
		"gsap": "^3.12.7",
		"lefthook": "^1.10.1",
		"lenis": "^1.1.19",
		"lint-staged": "^15.3.0",
		"motion": "^11.16.3",
		"postcss-plugin-hover": "^1.0.1",
		"zod": "^3.24.1"
	}
}
